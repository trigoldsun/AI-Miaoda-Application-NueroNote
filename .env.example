# FluxNote 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# =============================================================================
# Flask 配置
# =============================================================================
FLASK_ENV=development
FLASK_DEBUG=true
APP_PORT=5000

# =============================================================================
# 安全配置（生产环境必须修改）
# =============================================================================
# 应用密钥 - 用于会话加密（必填）
FLUX_SECRET_KEY=change_me_to_a_random_string_at_least_32_chars

# JWT密钥 - 用于Token签名（必填）
FLUX_JWT_SECRET=change_me_to_a_different_random_string

# =============================================================================
# 数据库配置
# =============================================================================
# 数据库类型: sqlite, postgresql, mysql, auto
DATABASE_TYPE=sqlite

# SQLite数据库路径（仅DATABASE_TYPE=sqlite时使用）
FLUX_DB=fluxnote.db

# PostgreSQL/MySQL连接URL（仅非sqlite时使用）
# 格式: postgresql://user:password@host:5432/fluxnote
# 格式: mysql+pymysql://user:password@host:3306/fluxnote
DATABASE_URL=

# 连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CORS 配置
# =============================================================================
CORS_ORIGINS=*

# =============================================================================
# 云存储配置（可选）
# =============================================================================
# 阿里云OSS
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_REGION=cn-hangzhou

# 腾讯云COS
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_COS_BUCKET=
# TENCENT_COS_REGION=ap-guangzhou

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=fluxnote.log

# =============================================================================
# Docker 配置
# =============================================================================
DOCKER_TARGET=development

# PostgreSQL (Docker)
POSTGRES_USER=fluxnote
POSTGRES_PASSWORD=change_password
POSTGRES_PORT=5432

# Redis (Docker)
REDIS_PORT=6379

# Nginx (Docker)
NGINX_PORT=80
NGINX_SSL_PORT=443
