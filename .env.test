# FluxNote 测试配置
# 用于开发和测试环境

# 应用配置
FLUX_DEBUG=true
FLUX_HOST=127.0.0.1
FLUX_PORT=5001

# 安全配置
FLUX_SECURITY__SECRET_KEY=test-secret-key-do-not-use-in-production
FLUX_SECURITY__JWT_SECRET=test-jwt-secret-do-not-use-in-production
FLUX_SECURITY__TOKEN_EXPIRE_HOURS=24
FLUX_SECURITY__MAX_LOGIN_FAILS=5
FLUX_SECURITY__LOCKOUT_DURATION=900

# 数据库配置（使用SQLite内存数据库进行测试）
FLUX_DATABASE__URL=sqlite:///:memory:
FLUX_DATABASE__POOL_SIZE=5
FLUX_DATABASE__MAX_OVERFLOW=10
FLUX_DATABASE__POOL_TIMEOUT=30
FLUX_DATABASE__POOL_RECYCLE=3600
FLUX_DATABASE__POOL_PRE_PING=true
FLUX_DATABASE__ECHO=false
FLUX_DATABASE__CACHE_SIZE=2000

# 存储配置
FLUX_STORAGE__MAX_CONTENT_LENGTH=1048576
FLUX_STORAGE__QUOTA_FREE=536870912
FLUX_STORAGE__QUOTA_PRO=10737418240
FLUX_STORAGE__QUOTA_TEAM=107374182400

# Redis配置（测试时禁用）
FLUX_REDIS__ENABLED=false
FLUX_REDIS__URL=redis://localhost:6379/0
FLUX_REDIS__SOCKET_TIMEOUT=5
FLUX_REDIS__SOCKET_CONNECT_TIMEOUT=5
FLUX_REDIS__SOCKET_KEEPALIVE=true
FLUX_REDIS__MAX_CONNECTIONS=50
FLUX_REDIS__HEALTH_CHECK_INTERVAL=30
FLUX_REDIS__USER_CACHE_TTL=300
FLUX_REDIS__VAULT_CACHE_TTL=60
FLUX_REDIS__TOKEN_CACHE_TTL=86400
FLUX_REDIS__RATE_LIMIT_TTL=60

# 限流配置
FLUX_RATE_LIMIT__ENABLED=false
FLUX_RATE_LIMIT__IP_LIMIT_PER_MINUTE=60
FLUX_RATE_LIMIT__USER_LIMIT_PER_MINUTE=120
FLUX_RATE_LIMIT__AUTH_LIMIT_PER_MINUTE=10
FLUX_RATE_LIMIT__WINDOW_SECONDS=60

# 云存储配置
FLUX_CLOUD__ENABLED=false
FLUX_CLOUD__DEFAULT_PROVIDER=aliyunpan
FLUX_CLOUD__SYNC_INTERVAL=300
FLUX_CLOUD__CHUNK_SIZE=10485760
